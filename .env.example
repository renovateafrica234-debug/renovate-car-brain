# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-your-key

# Railway / Brain API
BRAIN_API_URL=https://your-app.up.railway.app
API_SECRET=your-random-secret

# WhatsApp Business API
WHATSAPP_TOKEN=EAA-your-token
WHATSAPP_PHONE_ID=your-phone-id

# Twitter/X API
TWITTER_API_KEY=your-key
TWITTER_API_SECRET=your-secret
TWITTER_ACCESS_TOKEN=your-token
TWITTER_ACCESS_SECRET=your-secret

# Redis (Railway auto-generates this)
REDIS_URL=redis://default:password@host:port

# Vercel
NEXT_PUBLIC_APP_URL=https://your-dashboard.vercel.app
NEXT_PUBLIC_WHATSAPP_NUMBER=+2348012345678
